# ─── IceData Forge — Production Environment ───
# Copy to .env and fill in secrets.
# docker compose -f docker-compose.prod.yml --env-file .env up -d

# Docker Hub
DOCKER_HUB_USER=icedataforge
TAG=2026.05.15

# PostgreSQL
POSTGRES_PASSWORD=<generate-a-strong-password>

# JWT (at least 32 chars)
JWT_SECRET=<generate-a-strong-random-secret>

# OpenAI (optional — AI features disabled without it)
OPENAI_API_KEY=sk-...

# MCP Server
MCP_API_KEY=<generate-another-secret>

# n8n
N8N_ENCRYPTION_KEY=<generate-a-32-char-key>
N8N_WEBHOOK_SECRET=<generate-another-secret>

# Telegram Bot (optional)
BOT_TOKEN=<your-bot-token-from-botfather>

# Ports (change if conflicts)
API_PORT=8080
MCP_PORT=3001
DASHBOARD_PORT=80
N8N_PORT=5678

# Logging
RUST_LOG=info

# SSH Deploy (optional — set in CI only)
# SSH_HOST=your-server.com
# SSH_USER=deploy
# SSH_KEY=/path/to/deploy-key
# SSH_PATH=/opt/icedata-forge
