{
  "name": "ICE DATA — AI Analysis (Daily)",
  "nodes": [
    {
      "id": "a1b2c3d4-0002-0001-0000-000000000001",
      "name": "Daily Schedule (4 AM)",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.1,
      "position": [250, 300],
      "parameters": {
        "rule": {
          "interval": [{ "field": "hours", "hoursInterval": 24 }]
        }
      }
    },
    {
      "id": "a1b2c3d4-0002-0001-0000-000000000002",
      "name": "Get Active Players",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [450, 300],
      "parameters": {
        "url": "={{ $env.API_BASE_URL }}/v1/analytics/leaders?metric=points&limit=50",
        "options": {},
        "method": "GET",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": false,
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "=Bearer {{ $env.API_KEY }}" }
          ]
        }
      }
    },
    {
      "id": "a1b2c3d4-0002-0001-0000-000000000003",
      "name": "Extract Player IDs",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [650, 300],
      "parameters": {
        "jsCode": "const data = $input.first().json.data;\nconst players = data.leaders.map(l => ({\n  player_id: l.player_id,\n  name: l.name\n}));\nreturn players.map(p => ({ json: p }));"
      }
    },
    {
      "id": "a1b2c3d4-0002-0001-0000-000000000004",
      "name": "Loop Over Players",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [850, 300],
      "parameters": {
        "batchSize": 5,
        "options": {}
      }
    },
    {
      "id": "a1b2c3d4-0002-0001-0000-000000000005",
      "name": "Analyze Player",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1050, 300],
      "parameters": {
        "url": "={{ $env.API_BASE_URL }}/v1/players/{{ $json.player_id }}/ai-analysis?depth=standard",
        "options": {},
        "method": "GET",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": false,
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "=Bearer {{ $env.API_KEY }}" }
          ]
        }
      }
    },
    {
      "id": "a1b2c3d4-0002-0001-0000-000000000006",
      "name": "Wait 2s (rate limit)",
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1,
      "position": [1250, 300],
      "parameters": {
        "amount": 2,
        "unit": "seconds"
      }
    }
  ],
  "connections": {
    "a1b2c3d4-0002-0001-0000-000000000001": {
      "main": [[
        { "node": "a1b2c3d4-0002-0001-0000-000000000002", "type": "main", "index": 0 }
      ]]
    },
    "a1b2c3d4-0002-0001-0000-000000000002": {
      "main": [[
        { "node": "a1b2c3d4-0002-0001-0000-000000000003", "type": "main", "index": 0 }
      ]]
    },
    "a1b2c3d4-0002-0001-0000-000000000003": {
      "main": [[
        { "node": "a1b2c3d4-0002-0001-0000-000000000004", "type": "main", "index": 0 }
      ]]
    },
    "a1b2c3d4-0002-0001-0000-000000000004": {
      "main": [[
        { "node": "a1b2c3d4-0002-0001-0000-000000000005", "type": "main", "index": 0 }
      ]]
    },
    "a1b2c3d4-0002-0001-0000-000000000005": {
      "main": [[
        { "node": "a1b2c3d4-0002-0001-0000-000000000006", "type": "main", "index": 0 }
      ]]
    }
  },
  "settings": {
    "timezone": "America/New_York",
    "saveManualExecutions": true,
    "callerPolicy": "workflowsFromSameOwner"
  },
  "staticData": null,
  "tags": ["ice-data", "ai", "analysis"]
}
